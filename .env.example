# ─────────────────────────────────────────────────────────────
#  Infinitee Xclusives — Environment Configuration
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Django Core
DJANGO_SECRET_KEY=replace-with-a-long-random-string-at-least-50-chars
DJANGO_DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.com

# MySQL Database
DB_NAME=infinitee_db
DB_USER=infinitee_user
DB_PASSWORD=your-strong-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

# Fernet Encryption Key (for API credentials at rest)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-base64-encoded-fernet-key=

# Anthropic (fallback if not stored in DB)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
